<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.qy.dch.mapper.FusionMapper">

    <!-- 结果映射 -->
    <resultMap id="FusionResultMap" type="com.qy.dch.dto.FusionDTO">
        <id column="id" property="fusionId"/>
        <result column="title" property="title"/>
        <result column="summary" property="summary"/>
        <result column="timeline" property="timeline"/>
        <result column="content" property="content"/>
        <result column="entities" property="entities"/>
        <result column="labels" property="labels"/>
        <result column="source_ids" property="sourceIds"/>
        <result column="model_used" property="modelUsed"/>
        <result column="create_time" property="createTime"/>
        <result column="update_time" property="updateTime"/>
    </resultMap>

    <!-- 插入融合报告 -->
    <insert id="insertFusion" parameterType="com.qy.dch.dto.FusionDTO" useGeneratedKeys="true" keyProperty="fusionId">
        INSERT INTO fusion_report (
            title,
            summary,
            timeline,
            content,
            entities,
            labels,
            source_ids,
            model_used,
            create_time,
            update_time
        ) VALUES (
            #{title},
            #{summary},
            #{timeline},
            #{content},
            #{entities},
            #{labels},
            #{sourceIds},
            #{modelUsed},
            #{createTime},
            #{updateTime}
        )
    </insert>

    <!-- 根据ID查询融合报告 -->
    <select id="selectFusionById" parameterType="Long" resultMap="FusionResultMap">
        SELECT
            id,
            title,
            summary,
            timeline,
            content,
            entities,
            labels,
            source_ids,
            model_used,
            create_time,
            update_time
        FROM fusion_report
        WHERE id = #{id}
    </select>

    <!-- 分页查询融合报告列表 -->
    <select id="selectFusionList" resultMap="FusionResultMap">
        SELECT
            id,
            title,
            summary,
            timeline,
            content,
            entities,
            labels,
            source_ids,
            model_used,
            create_time,
            update_time
        FROM fusion_report
        ORDER BY create_time DESC
        LIMIT #{limit} OFFSET #{offset}
    </select>

    <!-- 查询融合报告总数 -->
    <select id="selectFusionCount" resultType="int">
        SELECT COUNT(*) FROM fusion_report
    </select>

    <!-- 更新融合报告 -->
    <update id="updateFusion" parameterType="com.qy.dch.dto.FusionDTO">
        UPDATE fusion_report SET
            title = #{title},
            summary = #{summary},
            timeline = #{timeline},
            content = #{content},
            entities = #{entities},
            labels = #{labels},
            update_time = #{updateTime}
        WHERE id = #{fusionId}
    </update>

</mapper>